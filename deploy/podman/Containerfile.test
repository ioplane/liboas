# liboas test image (CI)
# Based on liboas-dev, pre-builds project for fast test execution.
#
# Build:
#   podman build -t liboas-dev:latest -f deploy/podman/Containerfile deploy/podman/
#   podman build -t liboas-test:latest -f deploy/podman/Containerfile.test .
#
# Run tests:
#   podman run --rm localhost/liboas-test:latest
#
# Run quality pipeline:
#   podman run --rm --security-opt seccomp=unconfined \
#     -v ./:/workspace:Z localhost/liboas-test:latest ./scripts/quality.sh

FROM localhost/liboas-dev:latest

LABEL maintainer="liboas"
LABEL description="liboas pre-built test image"

WORKDIR /workspace

# Copy project source
COPY . /workspace/

# Configure and build
RUN cmake --preset clang-debug \
    && cmake --build --preset clang-debug

# Default: run full test suite
CMD ["ctest", "--preset", "clang-debug", "--output-on-failure"]
