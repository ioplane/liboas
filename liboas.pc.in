prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: liboas
Description: OpenAPI 3.2 parsing, validation, and serving library
Version: @PROJECT_VERSION@
URL: https://github.com/ioplane/liboas

Requires: yyjson
Libs: -L${libdir} -loas
Cflags: -I${includedir}
